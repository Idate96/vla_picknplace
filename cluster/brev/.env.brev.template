# Brev configuration for vla_picknplace.
# Copy to .env.brev and edit:
#
#   cp cluster/brev/.env.brev.template cluster/brev/.env.brev

export CLUSTER_TYPE=brev

# Brev SSH alias or instance name from `brev ls --all`.
export BREV_INSTANCE_NAME=""

# Remote paths on the Brev VM.
export BREV_CODE_DIR=/home/nvidia/code/vla_picknplace
export BREV_LOGS_DIR=/home/nvidia/logs/vla_picknplace
export BREV_DATA_DIR=/home/nvidia/data/vla_picknplace

# Local project path. Defaults to this repo root if unset.
# export LOCAL_PROJECT_DIR=/home/lorenzo/git/vla_picknplace

# Optional: set to 1 only if you intentionally need ignored files under outputs/.
export BREV_SYNC_OUTPUTS="${BREV_SYNC_OUTPUTS:-0}"

# Optional auth/secrets forwarded to remote train commands.
export HF_TOKEN="${HF_TOKEN:-}"
export WANDB_API_KEY="${WANDB_API_KEY:-}"
export WANDB_USERNAME="${WANDB_USERNAME:-}"
export WANDB_MODE="${WANDB_MODE:-online}"
